diff --git a/tests/test_forward_tracker.py b/tests/test_forward_tracker.py
new file mode 100644
index 0000000..f31a35c
--- /dev/null
+++ b/tests/test_forward_tracker.py
@@ -0,0 +1,75 @@
+from datetime import datetime, timedelta, timezone
+
+import pandas as pd
+
+from src.database import init_database
+from src.forward_tracker import compute_forward_returns, get_signal_outcomes, record_signal_snapshot, update_matured_signals
+
+
+def test_signal_snapshot_creation(tmp_path):
+    db_path = tmp_path / "signals.db"
+    init_database(db_path)
+    signal_id = record_signal_snapshot("AAA", "trade_setup", 5, "Tradeable", db_path=db_path)
+    outcomes = get_signal_outcomes(db_path)
+    assert outcomes[0]["signal_id"] == signal_id
+    assert outcomes[0]["ticker"] == "AAA"
+
+
+def test_forward_return_computation_and_bullish_hit(tmp_path):
+    db_path = tmp_path / "signals.db"
+    init_database(db_path)
+    created_at = datetime.now(timezone.utc) - timedelta(days=10)
+    signal_id = record_signal_snapshot("AAA", "trade_setup", 5, "Tradeable", db_path=db_path)
+    with init_conn(db_path) as conn:
+        conn.execute("UPDATE signal_snapshots SET created_at = ? WHERE signal_id = ?", (created_at.isoformat(timespec="seconds"), signal_id))
+    series = pd.Series([100, 101, 102, 103, 104, 106, 107], index=pd.date_range(created_at.date(), periods=7))
+    updated = update_matured_signals({"AAA": series}, db_path=db_path, as_of=datetime.now(timezone.utc))
+    outcome = get_signal_outcomes(db_path)[0]
+    assert updated == 1
+    assert outcome["is_matured"] == 1
+    assert outcome["hit"] == 1
+
+
+def test_avoid_chase_outcome_tracking(tmp_path):
+    db_path = tmp_path / "signals.db"
+    init_database(db_path)
+    created_at = datetime.now(timezone.utc) - timedelta(days=10)
+    signal_id = record_signal_snapshot("AAA", "trade_setup", 5, "Avoid Chase", db_path=db_path)
+    with init_conn(db_path) as conn:
+        conn.execute("UPDATE signal_snapshots SET created_at = ? WHERE signal_id = ?", (created_at.isoformat(timespec="seconds"), signal_id))
+    series = pd.Series([100, 99, 98, 97, 96, 95, 94], index=pd.date_range(created_at.date(), periods=7))
+    update_matured_signals({"AAA": series}, db_path=db_path, as_of=datetime.now(timezone.utc))
+    outcome = get_signal_outcomes(db_path)[0]
+    assert outcome["avoided_bad_trade"] == 1
+    assert outcome["false_negative"] == 0
+
+
+def test_unmatured_signal_stays_open(tmp_path):
+    db_path = tmp_path / "signals.db"
+    init_database(db_path)
+    record_signal_snapshot("AAA", "trade_setup", 20, "Watch", db_path=db_path)
+    updated = update_matured_signals({"AAA": pd.Series(dtype=float)}, db_path=db_path, as_of=datetime.now(timezone.utc))
+    assert updated == 0
+    assert get_signal_outcomes(db_path)[0]["is_matured"] == 0
+
+
+def test_compute_forward_returns():
+    idx = pd.date_range("2026-01-01", periods=25)
+    returns = compute_forward_returns(pd.Series(range(100, 125), index=idx), "2026-01-01", horizons=[5])
+    assert returns["forward_5d_return"] > 0
+    assert returns["max_runup_during_horizon"] > 0
+
+
+from contextlib import contextmanager
+import sqlite3
+
+
+@contextmanager
+def init_conn(path):
+    conn = sqlite3.connect(path)
+    try:
+        yield conn
+        conn.commit()
+    finally:
+        conn.close()
+
