+from src.signal_evaluator import calculate_base_rate, calculate_validation_metrics
+
+
+def test_hit_rate_base_rate_and_excess_by_group():
+    records = [
+        {"horizon_days": 5, "classification_at_creation": "Tradeable", "is_matured": 1, "hit": 1, "forward_5d_abnormal_return": 0.02, "max_drawdown_during_horizon": -0.01},
+        {"horizon_days": 5, "classification_at_creation": "Tradeable", "is_matured": 1, "hit": 0, "forward_5d_abnormal_return": -0.01, "max_drawdown_during_horizon": -0.03},
+        {"horizon_days": 5, "classification_at_creation": "Watch", "is_matured": 1, "hit": 1, "forward_5d_abnormal_return": 0.03, "max_drawdown_during_horizon": -0.01},
+    ]
+    metrics = calculate_validation_metrics(records)
+    tradeable = next(item for item in metrics if item["classification_at_creation"] == "Tradeable")
+    assert tradeable["hit_rate"] == 0.5
+    assert calculate_base_rate(records, {"horizon_days": 5}) == 2 / 3
+    assert tradeable["excess_hit_rate"] == 0.5 - 2 / 3
+
