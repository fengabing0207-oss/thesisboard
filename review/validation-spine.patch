new file mode 100644
index 0000000..94ce080
--- /dev/null
+++ b/src/event_study.py
@@ -0,0 +1,127 @@
+from __future__ import annotations
+
+from datetime import datetime, timedelta
+
+import pandas as pd
+
+from .abnormal_returns import abnormal_return_summary, calculate_raw_return
+from .horizons import EVENT_REACTION_HORIZONS
+
+
+def run_event_study(
+    ticker: str,
+    event_date,
+    catalyst_type: str,
+    sentiment: str,
+    ticker_prices: pd.Series,
+    benchmark_prices: pd.Series,
+    event_timestamp: datetime | None = None,
+    benchmark: str = "SPY",
+    sector_proxy: str | None = None,
+    sector_proxy_prices: pd.Series | None = None,
+    peer_basket_prices: dict[str, pd.Series] | None = None,
+    volume_series: pd.Series | None = None,
+    horizons: list[int] | None = None,
+) -> list[dict]:
+    horizons = horizons or EVENT_REACTION_HORIZONS
+    results = []
+    for horizon in horizons:
+        end_date = pd.Timestamp(event_date) + timedelta(days=horizon)
+        abnormal = abnormal_return_summary(
+            ticker_prices,
+            benchmark_prices,
+            event_date,
+            end_date,
+            sector_proxy=sector_proxy,
+            sector_proxy_prices=sector_proxy_prices,
+        )
+        sector_adjusted = None
+        if abnormal["sector_proxy_return"] is not None and abnormal["raw_return"] is not None:
+            sector_adjusted = abnormal["raw_return"] - abnormal["sector_proxy_return"]
+        volume_reaction = _volume_reaction(volume_series, event_date, end_date)
+        peer_reaction = _peer_basket_reaction(peer_basket_prices, event_date, end_date)
+        causality_confidence = "medium" if event_timestamp else "low"
+        notes = [] if event_timestamp else ["Daily data cannot establish intraday causal ordering."]
+        label = classify_reaction(sentiment, abnormal["combined_abnormal_return"], peer_reaction, causality_confidence)
+        results.append(
+            {
+                "ticker": ticker.upper(),
+                "event_date": str(pd.Timestamp(event_date).date()),
+                "event_timestamp": event_timestamp.isoformat() if event_timestamp else None,
+                "catalyst_type": catalyst_type,
+                "sentiment": sentiment,
+                "benchmark": benchmark,
+                "sector_proxy": sector_proxy,
+                "horizon_days": horizon,
+                "raw_return": abnormal["raw_return"],
+                "market_adjusted_return": _safe_difference(abnormal["raw_return"], abnormal["market_return"]),
+                "beta_adjusted_return": abnormal["beta_adjusted_return"],
+                "sector_adjusted_return": sector_adjusted,
+                "combined_abnormal_return": abnormal["combined_abnormal_return"],
+                "volume_reaction": volume_reaction,
+                "peer_basket_reaction": peer_reaction,
+                "reaction_label": label,
+                "confidence": _confidence(abnormal["data_quality_flag"], causality_confidence),
+                "causality_confidence": causality_confidence,
+                "data_quality_flag": abnormal["data_quality_flag"],
+                "notes": notes,
+            }
+        )
+    return results
+
+
+def classify_reaction(
+    sentiment: str,
+    abnormal_return: float | None,
+    peer_basket_reaction: float | None = None,
+    causality_confidence: str = "low",
+) -> str:
+    if abnormal_return is None:
+        return "Inconclusive"
+    normalized = sentiment.lower()
+    threshold = 0.005
+    if normalized == "positive" and abnormal_return > threshold:
+        return "Positive Abnormal Reaction"
+    if normalized == "positive" and abnormal_return < -threshold:
+        return "Sell the News"
+    if normalized == "negative" and abnormal_return >= 0:
+        return "Bad News Absorbed"
+    if normalized == "negative" and abnormal_return < -threshold:
+        return "Negative Abnormal Reaction"
+    if normalized in {"neutral", "mixed"}:
+        if peer_basket_reaction is not None and abs(abnormal_return) > threshold and abs(peer_basket_reaction) > threshold:
+            return "Positive Abnormal Reaction" if abnormal_return > 0 else "Negative Abnormal Reaction"
+        return "Inconclusive"
+    if causality_confidence == "low":
+        return "Inconclusive"
+    return "No Meaningful Abnormal Reaction" if abs(abnormal_return) <= threshold else "Inconclusive"
+
+
+def _volume_reaction(volume_series: pd.Series | None, start_date, end_date) -> float | None:
+    if volume_series is None or volume_series.empty:
+        return None
+    series = pd.Series(volume_series).dropna().sort_index()
+    window = series.loc[(series.index >= pd.Timestamp(start_date)) & (series.index <= pd.Timestamp(end_date))]
+    trailing = series.loc[series.index < pd.Timestamp(start_date)].tail(20)
+    if window.empty or trailing.empty or trailing.mean() == 0:
+        return None
+    return float(window.mean() / trailing.mean())
+
+
+def _peer_basket_reaction(peer_basket_prices: dict[str, pd.Series] | None, start_date, end_date) -> float | None:
+    if not peer_basket_prices:
+        return None
+    returns = [calculate_raw_return(series, start_date, end_date) for series in peer_basket_prices.values()]
+    valid = [value for value in returns if value is not None]
+    return float(sum(valid) / len(valid)) if valid else None
+
+
+def _safe_difference(left, right):
+    return None if left is None or right is None else float(left - right)
+
+
+def _confidence(data_quality_flag: str, causality_confidence: str) -> float:
+    if data_quality_flag != "ok":
+        return 0.35
+    return 0.7 if causality_confidence == "medium" else 0.5
+
diff --git a/src/forward_tracker.py b/src/forward_tracker.py
new file mode 100644
index 0000000..1429704
--- /dev/null
+++ b/src/forward_tracker.py
@@ -0,0 +1,232 @@
+from __future__ import annotations
+
+import json
+import sqlite3
+import uuid
+from datetime import datetime, timezone
+from pathlib import Path
+
+import pandas as pd
+
+from .abnormal_returns import abnormal_return_summary, calculate_raw_return
+from .config import DB_PATH
+from .database import connect, init_database
+from .horizons import EVENT_REACTION_HORIZONS, SWING_HORIZON, THEME_HORIZON
+
+
+FORWARD_HORIZONS = [*EVENT_REACTION_HORIZONS, SWING_HORIZON, THEME_HORIZON]
+
+
+def record_signal_snapshot(
+    ticker: str,
+    signal_type: str,
+    horizon_days: int,
+    classification_at_creation: str,
+    score_at_creation: float | None = None,
+    price_at_creation: float | None = None,
+    benchmark_at_creation: float | None = None,
+    sector_proxy_at_creation: str | None = None,
+    market_regime_at_creation: str | None = None,
+    theme: str | None = None,
+    basket: list[str] | None = None,
+    evidence: dict | None = None,
+    rule_version: str = "validation_v1",
+    model_version: str | None = None,
+    thesis_or_event_id: str | None = None,
+    db_path: Path | str = DB_PATH,
+) -> str:
+    init_database(db_path)
+    signal_id = str(uuid.uuid4())
+    with connect(db_path) as conn:
+        conn.execute(
+            """
+            INSERT INTO signal_snapshots (
+                signal_id, created_at, ticker, signal_type, horizon_days, thesis_or_event_id,
+                classification_at_creation, score_at_creation, price_at_creation, benchmark_at_creation,
+                sector_proxy, market_regime, theme, basket, evidence_json, rule_version, model_version
+            )
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (
+                signal_id,
+                _now(),
+                ticker.upper(),
+                signal_type,
+                horizon_days,
+                thesis_or_event_id,
+                classification_at_creation,
+                score_at_creation,
+                price_at_creation,
+                benchmark_at_creation,
+                sector_proxy_at_creation,
+                market_regime_at_creation,
+                theme,
+                json.dumps(basket or []),
+                json.dumps(evidence or {}),
+                rule_version,
+                model_version,
+            ),
+        )
+    return signal_id
+
+
+def compute_forward_returns(
+    price_series: pd.Series,
+    start_date,
+    benchmark_series: pd.Series | None = None,
+    sector_proxy_series: pd.Series | None = None,
+    horizons: list[int] | None = None,
+) -> dict:
+    horizons = horizons or FORWARD_HORIZONS
+    outcomes: dict[str, float | None] = {}
+    for horizon in horizons:
+        end_date = pd.Timestamp(start_date) + pd.Timedelta(days=horizon)
+        raw = calculate_raw_return(price_series, start_date, end_date)
+        outcomes[f"forward_{horizon}d_return"] = raw
+        if benchmark_series is not None:
+            abnormal = abnormal_return_summary(price_series, benchmark_series, start_date, end_date, sector_proxy_prices=sector_proxy_series)
+            outcomes[f"forward_{horizon}d_abnormal_return"] = abnormal["combined_abnormal_return"]
+        else:
+            outcomes[f"forward_{horizon}d_abnormal_return"] = raw
+    outcomes.update(_runup_drawdown(price_series, start_date, max(horizons)))
+    return outcomes
+
+
+def update_matured_signals(
+    price_lookup: dict[str, pd.Series],
+    benchmark_series: pd.Series | None = None,
+    db_path: Path | str = DB_PATH,
+    as_of: datetime | None = None,
+) -> int:
+    init_database(db_path)
+    as_of = as_of or datetime.now(timezone.utc)
+    updated = 0
+    with connect(db_path) as conn:
+        signals = conn.execute("SELECT * FROM signal_snapshots").fetchall()
+        for signal in signals:
+            created_at = pd.Timestamp(signal["created_at"])
+            if created_at + pd.Timedelta(days=signal["horizon_days"]) > pd.Timestamp(as_of):
+                _upsert_outcome(conn, signal["signal_id"], {"is_matured": 0, "data_quality_flag": "ok"}, signal["classification_at_creation"])
+                continue
+            prices = price_lookup.get(signal["ticker"])
+            if prices is None:
+                _upsert_outcome(conn, signal["signal_id"], {"is_matured": 0, "data_quality_flag": "insufficient_price_history"}, signal["classification_at_creation"])
+                continue
+            returns = compute_forward_returns(prices, created_at, benchmark_series)
+            returns["is_matured"] = 1
+            returns["data_quality_flag"] = "ok"
+            _upsert_outcome(conn, signal["signal_id"], returns, signal["classification_at_creation"])
+            updated += 1
+    return updated
+
+
+def get_signal_outcomes(db_path: Path | str = DB_PATH) -> list[dict]:
+    init_database(db_path)
+    with connect(db_path) as conn:
+        rows = conn.execute(
+            """
+            SELECT signal_snapshots.*, signal_outcomes.*
+            FROM signal_snapshots
+            LEFT JOIN signal_outcomes ON signal_snapshots.signal_id = signal_outcomes.signal_id
+            ORDER BY signal_snapshots.created_at DESC
+            """
+        ).fetchall()
+        return [dict(row) for row in rows]
+
+
+def calculate_hit_rate(outcomes: list[dict], classification: str | None = None) -> float | None:
+    filtered = [item for item in outcomes if item.get("is_matured") and (classification is None or item.get("classification_at_creation") == classification)]
+    if not filtered:
+        return None
+    hits = [item for item in filtered if item.get("hit") == 1]
+    return len(hits) / len(filtered)
+
+
+def _upsert_outcome(conn: sqlite3.Connection, signal_id: str, values: dict, classification: str) -> None:
+    hit, avoided_bad_trade, false_negative = _classify_outcome(classification, values)
+    payload = {
+        "evaluated_at": _now(),
+        "is_matured": values.get("is_matured", 0),
+        "forward_1d_return": values.get("forward_1d_return"),
+        "forward_3d_return": values.get("forward_3d_return"),
+        "forward_5d_return": values.get("forward_5d_return"),
+        "forward_20d_return": values.get("forward_20d_return"),
+        "forward_1d_abnormal_return": values.get("forward_1d_abnormal_return"),
+        "forward_3d_abnormal_return": values.get("forward_3d_abnormal_return"),
+        "forward_5d_abnormal_return": values.get("forward_5d_abnormal_return"),
+        "forward_20d_abnormal_return": values.get("forward_20d_abnormal_return"),
+        "max_drawdown_during_horizon": values.get("max_drawdown_during_horizon"),
+        "max_runup_during_horizon": values.get("max_runup_during_horizon"),
+        "hit": hit,
+        "avoided_bad_trade": avoided_bad_trade,
+        "false_negative": false_negative,
+        "data_quality_flag": values.get("data_quality_flag", "ok"),
+    }
+    conn.execute(
+        """
+        INSERT INTO signal_outcomes (
+            signal_id, evaluated_at, is_matured, forward_1d_return, forward_3d_return,
+            forward_5d_return, forward_20d_return, forward_1d_abnormal_return,
+            forward_3d_abnormal_return, forward_5d_abnormal_return, forward_20d_abnormal_return,
+            max_drawdown_during_horizon, max_runup_during_horizon, hit, avoided_bad_trade,
+            false_negative, data_quality_flag
+        )
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+        ON CONFLICT(signal_id) DO UPDATE SET
+            evaluated_at=excluded.evaluated_at,
+            is_matured=excluded.is_matured,
+            forward_1d_return=excluded.forward_1d_return,
+            forward_3d_return=excluded.forward_3d_return,
+            forward_5d_return=excluded.forward_5d_return,
+            forward_20d_return=excluded.forward_20d_return,
+            forward_1d_abnormal_return=excluded.forward_1d_abnormal_return,
+            forward_3d_abnormal_return=excluded.forward_3d_abnormal_return,
+            forward_5d_abnormal_return=excluded.forward_5d_abnormal_return,
+            forward_20d_abnormal_return=excluded.forward_20d_abnormal_return,
+            max_drawdown_during_horizon=excluded.max_drawdown_during_horizon,
+            max_runup_during_horizon=excluded.max_runup_during_horizon,
+            hit=excluded.hit,
+            avoided_bad_trade=excluded.avoided_bad_trade,
+            false_negative=excluded.false_negative,
+            data_quality_flag=excluded.data_quality_flag
+        """,
+        (signal_id, *payload.values()),
+    )
+
+
+def _classify_outcome(classification: str, values: dict) -> tuple[int | None, int | None, int | None]:
+    abnormal = values.get("forward_5d_abnormal_return") or values.get("forward_3d_abnormal_return") or values.get("forward_1d_abnormal_return")
+    drawdown = values.get("max_drawdown_during_horizon") or 0
+    if not values.get("is_matured") or abnormal is None:
+        return None, None, None
+    if classification in {"Tradeable", "Watch", "Wait for Confirmation"}:
+        return int(abnormal > 0), None, None
+    if classification in {"Avoid", "Avoid Chase"}:
+        avoided = int(abnormal <= 0 or drawdown <= -0.05)
+        false_negative = int(abnormal >= 0.05)
+        return None, avoided, false_negative
+    return None, None, None
+
+
+def _runup_drawdown(price_series: pd.Series, start_date, horizon: int) -> dict:
+    series = pd.Series(price_series).dropna().sort_index()
+    start = pd.Timestamp(start_date)
+    if isinstance(series.index, pd.DatetimeIndex) and series.index.tz is None and start.tzinfo is not None:
+        start = start.tz_convert(None)
+    elif isinstance(series.index, pd.DatetimeIndex) and series.index.tz is not None and start.tzinfo is None:
+        start = start.tz_localize(series.index.tz)
+    end = start + pd.Timedelta(days=horizon)
+    window = series.loc[(series.index >= start) & (series.index <= end)]
+    if window.empty:
+        return {"max_drawdown_during_horizon": None, "max_runup_during_horizon": None}
+    start_price = window.iloc[0]
+    if start_price == 0:
+        return {"max_drawdown_during_horizon": None, "max_runup_during_horizon": None}
+    return {
+        "max_drawdown_during_horizon": float((window.min() / start_price) - 1),
+        "max_runup_during_horizon": float((window.max() / start_price) - 1),
+    }
+
+
+def _now() -> str:
+    return datetime.now(timezone.utc).isoformat(timespec="seconds")
