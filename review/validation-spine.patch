index 0000000..aa434e4
--- /dev/null
+++ b/docs/validation_methodology.md
@@ -0,0 +1,68 @@
+# Validation Methodology
+
+## Why Raw Return Is Insufficient
+
+Raw stock returns do not prove that a thesis, event, or setup was validated. A stock can rise because the whole market rose, because its sector moved, or because beta amplified a benchmark move. ThesisBoard therefore treats raw return as an input, not as validation by itself.
+
+## Abnormal Return Methodology
+
+The MVP calculates abnormal return by adjusting ticker return for market and, when available, sector or theme proxy movement.
+
+Default formula:
+
+```text
+abnormal_return = ticker_return - beta * market_return
+```
+
+When a sector or theme proxy is available:
+
+```text
+abnormal_return = ticker_return - 0.5 * beta * market_return - 0.5 * sector_proxy_return
+```
+
+SPY is the default market benchmark. Theme proxies include SMH for semiconductors, JETS for airlines, XLE for energy, XLY for consumer cyclicals, XLU for utilities and power, IGV for enterprise software, and BTC-USD for crypto infrastructure.
+
+## Beta-Adjusted Return
+
+Rolling beta is estimated from ticker and benchmark returns. If there is insufficient history, the MVP falls back to beta of 1.0 and marks the data quality accordingly where applicable.
+
+## Sector and Theme Proxy Adjustment
+
+Sector proxies reduce the risk of calling a ticker-specific move validated when the whole theme moved. If the proxy is missing, the system falls back to SPY-only abnormal return and records a missing proxy flag.
+
+## Event Study Limits
+
+Event studies are horizon-specific. ThesisBoard supports 1D immediate reaction and 3D event digestion horizons for event reactions. Daily data can show whether abnormal return followed an event date, but it cannot prove intraday causal ordering.
+
+## Timestamp Limits
+
+If an event timestamp is missing or only date-level, the system sets causality confidence to low and adds this guardrail: daily data cannot establish intraday causal ordering.
+
+## Horizon Definitions
+
+- 1D: immediate event reaction
+- 3D: short event digestion
+- 5D: swing setup validation
+- 20D: theme thesis validation
+- 60D: broader trend context
+
+A thesis should not collapse all horizons into one label. It can be confirmed on a 1D event reaction, unconfirmed on a 5D forward return, and still open on a 20D theme horizon.
+
+## Forward-Return Tracking
+
+Signal snapshots store the original classification, score, price, benchmark, sector proxy, market regime, theme, basket, evidence, and rule version. Matured outcomes later record forward returns, abnormal returns, drawdown, runup, hit status, avoided bad trade, and false negative flags.
+
+## Hit Rate and Base Rate
+
+Hit rate is not meaningful without base rate. ThesisBoard compares classification hit rate against the same universe and horizon base rate. If Tradeable 5D hit rate is 56% and base rate is 51%, the excess hit rate is +5 percentage points.
+
+Avoid and Avoid Chase outcomes are tracked separately from bullish classifications. Avoided bad trades and false negatives are not mixed into Tradeable hit-rate.
+
+## What The System Can Claim
+
+ThesisBoard can claim that a rule produced a recorded signal, that a future horizon matured, and that abnormal forward return met or failed the rule's hit definition.
+
+## What The System Cannot Claim
+
+ThesisBoard cannot claim predictive power before enough matured signals exist. It cannot claim causal intraday ordering from daily data. It cannot treat persuasive thesis text as validated unless the signal is tracked against future abnormal returns.
+
diff --git a/src/abnormal_returns.py b/src/abnormal_returns.py
new file mode 100644
index 0000000..02038af
--- /dev/null
+++ b/src/abnormal_returns.py
@@ -0,0 +1,160 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import date
+
+import pandas as pd
+
+
+THEME_PROXY_MAP = {
+    "AI Infrastructure": "SMH",
+    "Semiconductor": "SMH",
+    "Airlines": "JETS",
+    "Travel Rebound": "JETS",
+    "Cybersecurity": "HACK",
+    "Energy": "XLE",
+    "Consumer Cyclical": "XLY",
+    "Utilities": "XLU",
+    "Power": "XLU",
+    "Enterprise Software": "IGV",
+    "Crypto Infrastructure": "BTC-USD",
+}
+
+
+@dataclass
+class AbnormalReturnResult:
+    raw_return: float | None
+    market_return: float | None
+    beta: float | None
+    beta_adjusted_return: float | None
+    sector_proxy: str | None
+    sector_proxy_return: float | None
+    combined_abnormal_return: float | None
+    calculation_method: str
+    data_quality_flag: str
+
+    def as_dict(self) -> dict:
+        return self.__dict__.copy()
+
+
+def calculate_raw_return(price_series: pd.Series, start_date, end_date) -> float | None:
+    prices = _clean_price_series(price_series)
+    if prices.empty:
+        return None
+    start_price = _price_on_or_after(prices, start_date)
+    end_price = _price_on_or_before(prices, end_date)
+    if start_price is None or end_price is None or start_price == 0:
+        return None
+    return float((end_price / start_price) - 1)
+
+
+def estimate_rolling_beta(
+    ticker_returns: pd.Series,
+    benchmark_returns: pd.Series,
+    lookback_days: int = 120,
+) -> float | None:
+    joined = pd.concat([ticker_returns, benchmark_returns], axis=1, join="inner").dropna()
+    if len(joined) < max(20, min(lookback_days, 60)):
+        return None
+    joined = joined.tail(lookback_days)
+    benchmark = joined.iloc[:, 1]
+    variance = benchmark.var()
+    if variance == 0 or pd.isna(variance):
+        return None
+    return float(joined.iloc[:, 0].cov(benchmark) / variance)
+
+
+def calculate_market_adjusted_return(ticker_return: float, market_return: float) -> float:
+    return float(ticker_return - market_return)
+
+
+def calculate_beta_adjusted_return(ticker_return: float, beta: float, market_return: float) -> float:
+    return float(ticker_return - beta * market_return)
+
+
+def calculate_sector_adjusted_return(ticker_return: float, sector_or_theme_proxy_return: float) -> float:
+    return float(ticker_return - sector_or_theme_proxy_return)
+
+
+def calculate_combined_abnormal_return(
+    ticker_return: float,
+    beta: float,
+    market_return: float,
+    sector_proxy_return: float | None = None,
+    sector_weight: float = 0.5,
+) -> float:
+    if sector_proxy_return is None:
+        return calculate_beta_adjusted_return(ticker_return, beta, market_return)
+    market_weight = 1 - sector_weight
+    return float(ticker_return - market_weight * beta * market_return - sector_weight * sector_proxy_return)
+
+
+def abnormal_return_summary(
+    ticker_prices: pd.Series,
+    benchmark_prices: pd.Series,
+    start_date,
+    end_date,
+    sector_proxy: str | None = None,
+    sector_proxy_prices: pd.Series | None = None,
+    beta_lookback_days: int = 120,
+) -> dict:
+    raw_return = calculate_raw_return(ticker_prices, start_date, end_date)
+    market_return = calculate_raw_return(benchmark_prices, start_date, end_date)
+    if raw_return is None:
+        return AbnormalReturnResult(None, market_return, None, None, sector_proxy, None, None, "unavailable", "insufficient_price_history").as_dict()
+    if market_return is None:
+        return AbnormalReturnResult(raw_return, None, None, None, sector_proxy, None, None, "unavailable", "missing_benchmark_data").as_dict()
+
+    ticker_returns = _clean_price_series(ticker_prices).pct_change()
+    benchmark_returns = _clean_price_series(benchmark_prices).pct_change()
+    beta = estimate_rolling_beta(ticker_returns, benchmark_returns, beta_lookback_days)
+    if beta is None:
+        beta = 1.0
+
+    sector_return = None
+    data_quality = "ok"
+    if sector_proxy_prices is not None:
+        sector_return = calculate_raw_return(sector_proxy_prices, start_date, end_date)
+    if sector_proxy and sector_return is None:
+        data_quality = "missing_sector_proxy"
+
+    beta_adjusted = calculate_beta_adjusted_return(raw_return, beta, market_return)
+    combined = calculate_combined_abnormal_return(raw_return, beta, market_return, sector_return)
+    method = "beta_and_sector_adjusted" if sector_return is not None else "beta_adjusted_spy_only"
+    return AbnormalReturnResult(raw_return, market_return, beta, beta_adjusted, sector_proxy, sector_return, combined, method, data_quality).as_dict()
+
+
+def default_sector_proxy(theme: str | None) -> str | None:
+    if not theme:
+        return None
+    for key, proxy in THEME_PROXY_MAP.items():
+        if key.lower() in theme.lower():
+            return proxy
+    return None
+
+
+def _clean_price_series(price_series: pd.Series) -> pd.Series:
+    series = pd.Series(price_series).dropna()
+    if not isinstance(series.index, pd.DatetimeIndex):
+        series.index = pd.to_datetime(series.index)
+    return series.sort_index()
+
+
+def _price_on_or_after(prices: pd.Series, value: date | str):
+    timestamp = _normalize_timestamp_for_index(pd.Timestamp(value), prices.index)
+    candidates = prices.loc[prices.index >= timestamp]
+    return None if candidates.empty else float(candidates.iloc[0])
+
+
+def _price_on_or_before(prices: pd.Series, value: date | str):
+    timestamp = _normalize_timestamp_for_index(pd.Timestamp(value), prices.index)
+    candidates = prices.loc[prices.index <= timestamp]
+    return None if candidates.empty else float(candidates.iloc[-1])
+
+
+def _normalize_timestamp_for_index(timestamp: pd.Timestamp, index: pd.Index) -> pd.Timestamp:
+    if isinstance(index, pd.DatetimeIndex) and index.tz is None and timestamp.tzinfo is not None:
+        return timestamp.tz_convert(None)
+    if isinstance(index, pd.DatetimeIndex) and index.tz is not None and timestamp.tzinfo is None:
+        return timestamp.tz_localize(index.tz)
+    return timestamp
