@@ -0,0 +1,41 @@
+from __future__ import annotations
+
+EVENT_REACTION_HORIZONS = [1, 3]
+SWING_HORIZON = 5
+THEME_HORIZON = 20
+LONGER_CONTEXT_HORIZON = 60
+
+HORIZON_LABELS = {
+    1: "1D: immediate event reaction",
+    3: "3D: short event digestion",
+    5: "5D: swing setup validation",
+    20: "20D: theme thesis validation",
+    60: "60D: broader trend context",
+}
+
+SIGNAL_TYPE_DEFAULT_HORIZONS = {
+    "event_reaction": EVENT_REACTION_HORIZONS,
+    "trade_setup": [SWING_HORIZON],
+    "theme_thesis": [THEME_HORIZON],
+    "technical_extension": [SWING_HORIZON, THEME_HORIZON],
+    "basket_confirmation": [SWING_HORIZON, THEME_HORIZON],
+}
+
+
+def get_horizon_label(horizon_days: int) -> str:
+    validate_horizon(horizon_days)
+    return HORIZON_LABELS[horizon_days]
+
+
+def validate_horizon(horizon_days: int) -> int:
+    if horizon_days not in HORIZON_LABELS:
+        raise ValueError(f"Unsupported validation horizon: {horizon_days}")
+    return horizon_days
+
+
+def get_default_horizons_for_signal(signal_type: str) -> list[int]:
+    try:
+        return SIGNAL_TYPE_DEFAULT_HORIZONS[signal_type]
+    except KeyError as exc:
+        raise ValueError(f"Unsupported signal type: {signal_type}") from exc
+
