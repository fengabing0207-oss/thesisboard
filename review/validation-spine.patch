diff --git a/src/rule_based_thesis_validator.py b/src/rule_based_thesis_validator.py
new file mode 100644
index 0000000..210c400
--- /dev/null
+++ b/src/rule_based_thesis_validator.py
@@ -0,0 +1,156 @@
+from __future__ import annotations
+
+from .horizons import EVENT_REACTION_HORIZONS, SWING_HORIZON, THEME_HORIZON, get_horizon_label
+
+RULE_VERSION = "validation_v1"
+
+
+def validate_thesis(
+    price_features: dict,
+    abnormal_return_features: dict,
+    event_study_results: list[dict] | None = None,
+    basket_breadth: float | None = None,
+    news_signal: dict | None = None,
+    macro_regime: str = "Neutral",
+    extension_status: dict | None = None,
+) -> dict:
+    event_study_results = event_study_results or []
+    news_signal = news_signal or {}
+    extension_status = extension_status or {}
+
+    evidence_for: list[str] = []
+    evidence_against: list[str] = []
+    confirmation_needed: list[str] = []
+    invalidation_signals: list[str] = []
+    score = 0
+
+    if price_features.get("above_ma20"):
+        score += 2
+        evidence_for.append("Ticker is above the 20D moving average.")
+    else:
+        score -= 1
+        evidence_against.append("Ticker is not above the 20D moving average.")
+
+    abnormal_5d = abnormal_return_features.get("5d") or abnormal_return_features.get("forward_5d_abnormal_return")
+    if abnormal_5d is not None and abnormal_5d > 0:
+        score += 2
+        evidence_for.append("5D abnormal return is positive.")
+    elif abnormal_5d is not None:
+        score -= 2
+        evidence_against.append("5D abnormal return is negative.")
+    else:
+        confirmation_needed.append("Need 5D abnormal return validation.")
+
+    if basket_breadth is not None and basket_breadth > 0.5:
+        score += 2
+        evidence_for.append("Basket breadth is above 50%.")
+    elif basket_breadth is not None:
+        score -= 1
+        evidence_against.append("Basket breadth is not broad enough.")
+
+    if (price_features.get("volume_ratio") or 0) > 1.2:
+        score += 1
+        evidence_for.append("Volume is above 1.2x its recent average.")
+
+    high_rsi = (price_features.get("rsi") or 0) > 75
+    high_distance = (extension_status.get("distance_from_20d_ma") or price_features.get("distance_from_20d_ma") or 0) > 0.10
+    if high_rsi:
+        score -= 3
+        evidence_against.append("RSI is above 75.")
+        invalidation_signals.append("Overextension risk remains high.")
+    if high_distance:
+        score -= 3
+        evidence_against.append("Price is more than 10% above the 20D moving average.")
+        invalidation_signals.append("Wait for price to digest the move.")
+    if macro_regime == "Risk-Off":
+        score -= 2
+        evidence_against.append("Macro regime is Risk-Off.")
+
+    positive_event = _positive_event_reaction(event_study_results)
+    negative_event_after_positive_news = _negative_event_after_positive_news(event_study_results, news_signal)
+    if positive_event:
+        score += 2
+        evidence_for.append("Event study shows a positive abnormal reaction.")
+    if negative_event_after_positive_news:
+        score -= 3
+        evidence_against.append("Positive news produced a negative abnormal reaction.")
+
+    if _news_confirms_but_extended(news_signal, event_study_results, high_rsi, high_distance, price_features):
+        return {
+            "thesis_status_by_horizon": _status_by_horizon("Confirmed on 1D event reaction", "Unconfirmed on 5D forward return", "Still open on 20D theme horizon"),
+            "classification": "Avoid Chase",
+            "score": score,
+            "reason": "The catalyst was positively received, but the stock is already technically extended.",
+            "evidence_for": evidence_for,
+            "evidence_against": evidence_against,
+            "confirmation_needed": confirmation_needed,
+            "invalidation_signals": invalidation_signals,
+            "rule_version": RULE_VERSION,
+        }
+
+    classification = _classification(score, high_rsi or high_distance, bool(evidence_against))
+    return {
+        "thesis_status_by_horizon": _status_by_horizon(
+            "Confirmed on 1D event reaction" if positive_event else "Inconclusive on 1D event reaction",
+            "Confirmed on 5D swing horizon" if abnormal_5d and abnormal_5d > 0 else "Unconfirmed on 5D forward return",
+            "Still open on 20D theme horizon",
+        ),
+        "classification": classification,
+        "score": score,
+        "reason": _reason(classification, score, evidence_against),
+        "evidence_for": evidence_for,
+        "evidence_against": evidence_against,
+        "confirmation_needed": confirmation_needed,
+        "invalidation_signals": invalidation_signals,
+        "rule_version": RULE_VERSION,
+    }
+
+
+def _classification(score: int, extended: bool, conflicts: bool) -> str:
+    if score < 0:
+        return "Avoid"
+    if extended and score > 0:
+        return "Avoid Chase"
+    if conflicts and score >= 3:
+        return "Watch"
+    if score >= 6:
+        return "Tradeable"
+    if score >= 2:
+        return "Watch"
+    return "Wait for Confirmation"
+
+
+def _status_by_horizon(event_status: str, swing_status: str, theme_status: str) -> dict:
+    return {
+        get_horizon_label(EVENT_REACTION_HORIZONS[0]): event_status,
+        get_horizon_label(SWING_HORIZON): swing_status,
+        get_horizon_label(THEME_HORIZON): theme_status,
+    }
+
+
+def _positive_event_reaction(event_study_results: list[dict]) -> bool:
+    return any(item.get("reaction_label") == "Positive Abnormal Reaction" for item in event_study_results)
+
+
+def _negative_event_after_positive_news(event_study_results: list[dict], news_signal: dict) -> bool:
+    return news_signal.get("sentiment") == "positive" and any((item.get("combined_abnormal_return") or 0) < 0 for item in event_study_results)
+
+
+def _news_confirms_but_extended(news_signal: dict, event_study_results: list[dict], high_rsi: bool, high_distance: bool, price_features: dict) -> bool:
+    positive_news = news_signal.get("sentiment") == "positive"
+    positive_abnormal = any((item.get("combined_abnormal_return") or 0) > 0 for item in event_study_results)
+    volume_spike = (price_features.get("volume_ratio") or 0) > 1.5
+    return positive_news and positive_abnormal and (high_rsi or high_distance) and volume_spike
+
+
+def _reason(classification: str, score: int, evidence_against: list[str]) -> str:
+    if classification == "Tradeable":
+        return "Rule-based evidence is broad enough and extension risk is not high."
+    if classification == "Watch":
+        return "Evidence is constructive but still has conflicts or missing confirmation."
+    if classification == "Avoid Chase":
+        return "Setup has positive evidence but extension risk is high."
+    if classification == "Avoid":
+        return "Evidence conflicts or score is negative."
+    return "More forward-return confirmation is needed."
+
diff --git a/src/signal_evaluator.py b/src/signal_evaluator.py
new file mode 100644
index 0000000..c70fb66
--- /dev/null
+++ b/src/signal_evaluator.py
@@ -0,0 +1,93 @@
+from __future__ import annotations
+
+from statistics import median
+
+
+GROUP_FIELDS = ["horizon_days", "classification_at_creation", "theme", "ticker", "market_regime", "catalyst_type", "rule_version"]
+
+
+def calculate_validation_metrics(records: list[dict], group_by: list[str] | None = None) -> list[dict]:
+    group_by = group_by or ["horizon_days", "classification_at_creation"]
+    groups: dict[tuple, list[dict]] = {}
+    for record in records:
+        key = tuple(record.get(field) for field in group_by)
+        groups.setdefault(key, []).append(record)
+
+    metrics = []
+    for key, items in groups.items():
+        matured = [item for item in items if item.get("is_matured")]
+        hit_rate = _ratio([item for item in matured if item.get("hit") == 1], matured)
+        base_rate = calculate_base_rate(records, key_filter=dict(zip(group_by, key)))
+        excess = None if hit_rate is None or base_rate is None else hit_rate - base_rate
+        abnormal_values = [_forward_abnormal(item) for item in matured]
+        abnormal_values = [value for value in abnormal_values if value is not None]
+        drawdowns = [item.get("max_drawdown_during_horizon") for item in matured if item.get("max_drawdown_during_horizon") is not None]
+        metric = {
+            "signal_count": len(items),
+            "matured_count": len(matured),
+            "hit_rate": hit_rate,
+            "base_rate": base_rate,
+            "excess_hit_rate": excess,
+            "avg_forward_abnormal_return": _average(abnormal_values),
+            "median_forward_abnormal_return": median(abnormal_values) if abnormal_values else None,
+            "avg_max_drawdown": _average(drawdowns),
+            "false_positive_rate": calculate_false_positive_rate(matured),
+            "false_negative_rate": calculate_false_negative_rate(matured),
+        }
+        metric.update(dict(zip(group_by, key)))
+        metrics.append(metric)
+    return metrics
+
+
+def calculate_base_rate(records: list[dict], key_filter: dict | None = None) -> float | None:
+    key_filter = key_filter or {}
+    horizon = key_filter.get("horizon_days")
+    theme = key_filter.get("theme")
+    universe = [
+        record
+        for record in records
+        if record.get("is_matured")
+        and (horizon is None or record.get("horizon_days") == horizon)
+        and (theme is None or record.get("theme") == theme)
+    ]
+    if not universe:
+        return None
+    positives = [record for record in universe if (_forward_abnormal(record) or 0) > 0]
+    return len(positives) / len(universe)
+
+
+def calculate_false_positive_rate(records: list[dict]) -> float | None:
+    bullish = [item for item in records if item.get("classification_at_creation") in {"Tradeable", "Watch"}]
+    if not bullish:
+        return None
+    misses = [item for item in bullish if item.get("hit") == 0]
+    return len(misses) / len(bullish)
+
+
+def calculate_false_negative_rate(records: list[dict]) -> float | None:
+    avoided = [item for item in records if item.get("classification_at_creation") in {"Avoid", "Avoid Chase"}]
+    if not avoided:
+        return None
+    false_negatives = [item for item in avoided if item.get("false_negative") == 1]
+    return len(false_negatives) / len(avoided)
+
+
+def _forward_abnormal(record: dict) -> float | None:
+    horizon = record.get("horizon_days")
+    if horizon:
+        value = record.get(f"forward_{horizon}d_abnormal_return")
+        if value is not None:
+            return value
+    for key in ["forward_20d_abnormal_return", "forward_5d_abnormal_return", "forward_3d_abnormal_return", "forward_1d_abnormal_return"]:
+        if record.get(key) is not None:
+            return record[key]
+    return None
+
+
+def _average(values: list[float]) -> float | None:
+    return sum(values) / len(values) if values else None
+
+
+def _ratio(part: list, whole: list) -> float | None:
+    return len(part) / len(whole) if whole else None
+
