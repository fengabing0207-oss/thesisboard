+from src.rule_based_thesis_validator import validate_thesis
+
+
+def test_overextended_positive_catalyst_is_avoid_chase():
+    result = validate_thesis(
+        {"above_ma20": True, "rsi": 80, "distance_from_20d_ma": 0.12, "volume_ratio": 2.0},
+        {"5d": 0.03},
+        [{"combined_abnormal_return": 0.04, "reaction_label": "Positive Abnormal Reaction"}],
+        basket_breadth=0.7,
+        news_signal={"sentiment": "positive"},
+        macro_regime="Risk-On",
+    )
+    assert result["classification"] == "Avoid Chase"
+    assert result["reason"] == "The catalyst was positively received, but the stock is already technically extended."
+
+
+def test_positive_breadth_normal_extension_tradeable_or_watch():
+    result = validate_thesis(
+        {"above_ma20": True, "rsi": 60, "distance_from_20d_ma": 0.03, "volume_ratio": 1.3},
+        {"5d": 0.03},
+        [{"combined_abnormal_return": 0.02, "reaction_label": "Positive Abnormal Reaction"}],
+        basket_breadth=0.8,
+        news_signal={"sentiment": "positive"},
+        macro_regime="Risk-On",
+    )
+    assert result["classification"] in {"Watch", "Tradeable"}
+
+
+def test_risk_off_macro_penalty():
+    result = validate_thesis(
+        {"above_ma20": True, "rsi": 60, "distance_from_20d_ma": 0.03, "volume_ratio": 1.0},
+        {"5d": 0.01},
+        [],
+        basket_breadth=0.6,
+        macro_regime="Risk-Off",
+    )
+    assert "Macro regime is Risk-Off." in result["evidence_against"]
+
+
+def test_conflicting_evidence_not_tradeable():
+    result = validate_thesis(
+        {"above_ma20": True, "rsi": 60, "distance_from_20d_ma": 0.03, "volume_ratio": 1.3},
+        {"5d": -0.02},
+        [],
+        basket_breadth=0.8,
+        macro_regime="Risk-On",
+    )
+    assert result["classification"] in {"Watch", "Wait for Confirmation", "Avoid"}
+
